{%- if section.settings.fullwidth -%}
	{%- assign container = 'container-full' -%}
{%- elsif section.settings.max_width != blank -%}
	{%- assign container = 'bwp-container' -%}
{%- else -%}
	{%- assign container = 'container' -%}
{%- endif -%}

{%- assign max_width = '' -%}
{%- if section.settings.fullwidth == blank and section.settings.max_width != blank -%}
	{%- assign width_container = section.settings.max_width | plus: 0 -%}
	{%- capture max_width -%}style="max-width: {{ section.settings.max_width }};"{%- endcapture -%}
{%- endif -%}

{%- assign margin = '' -%}
{%- if section.settings.margin != blank -%}
  {%- capture margin -%}margin: {{ section.settings.margin }};{%- endcapture -%}
{%- endif -%}

{% assign margin = section.settings.margin | split: "|" %}
{% assign padding = section.settings.padding | split: "|" %}

{%- style -%}
	{%- if section.settings.fullwidth == blank and section.settings.max_width != blank and width_container > 1200 -%}
		@media (max-width: {{ section.settings.max_width }}) and (min-width: 1200px){
			#shopify-section-{{ section.id }} .bwp-container{
				padding-left:30px;
				padding-right:30px;
			}
		}
	{%- endif -%}
	{%- if margin[0] != blank or padding[0] != blank -%}
		#shopify-section-{{ section.id }} .wpbingo-why-choose-us{
			{%- if margin[0] != blank -%}margin: {{ margin[0] }};{%- endif -%}
			{%- if padding[0] != blank -%}padding:{{ padding[0] }};{%- endif -%}
		}
	{%- endif -%}
	{%- if margin[1] != blank or padding[1] != blank -%}
		@media (max-width:1200px){
			#shopify-section-{{ section.id }} .wpbingo-why-choose-us{
				{%- if margin[1] != blank -%}margin: {{ margin[1] }};{%- endif -%}
				{%- if padding[1] != blank -%}padding:{{ padding[1] }};{%- endif -%}
			}
		}
	{%- endif -%}
	{%- if margin[2] != blank or padding[2] != blank -%}
		@media (max-width:991px){
			#shopify-section-{{ section.id }} .wpbingo-why-choose-us{
				{%- if margin[2] != blank -%}margin: {{ margin[2] }};{%- endif -%}
				{%- if padding[2] != blank -%}padding:{{ padding[2] }};{%- endif -%}
			}
		}
	{%- endif -%}
	{%- if margin[3] != blank or padding[3] != blank -%}
		@media (max-width:767px){
			#shopify-section-{{ section.id }} .wpbingo-why-choose-us{
				{%- if margin[3] != blank -%}margin: {{ margin[3] }};{%- endif -%}
				{%- if padding[3] != blank -%}padding:{{ padding[3] }};{%- endif -%}
			}
		}
	{%- endif -%}

	{%- if section.blocks.size > 0 -%}
		{%- for block in section.blocks -%}
			{%- if block.type == 'css' -%}
				/* ===== SECTION TITLE STYLING ===== */
				#shopify-section-{{ section.id }} .why-choose-us__title{
					font-size: {{ block.settings.font_size_title }}px;
					line-height: {{ block.settings.line_height_title }}px;
					font-weight: {{ block.settings.font_weight_title }};
					letter-spacing: {{ block.settings.letter_spacing_title }}px;
					color: {{ block.settings.color_title }};
					margin: {{ block.settings.margin_title }};
					text-align: {{ block.settings.text_align }};
				}

				/* ===== FEATURE ITEM STYLING ===== */
				#shopify-section-{{ section.id }} .why-choose-us__feature-title{
					font-size: {{ block.settings.font_size_feature_title }}px;
					line-height: {{ block.settings.line_height_feature_title }}px;
					font-weight: {{ block.settings.font_weight_feature_title }};
					letter-spacing: {{ block.settings.letter_spacing_feature_title }}px;
					color: {{ block.settings.color_feature_title }};
					margin: {{ block.settings.margin_feature_title }};
				}

				#shopify-section-{{ section.id }} .why-choose-us__feature-desc{
					font-size: {{ block.settings.font_size_feature_desc }}px;
					line-height: {{ block.settings.line_height_feature_desc }}px;
					font-weight: {{ block.settings.font_weight_feature_desc }};
					color: {{ block.settings.color_feature_desc }};
					margin: {{ block.settings.margin_feature_desc }};
				}

				/* ===== ICON CONTAINER STYLING ===== */
				#shopify-section-{{ section.id }} .why-choose-us__icon-wrapper{
					background-color: {{ block.settings.icon_bg_color }};
					width: {{ block.settings.icon_size }}px;
					height: {{ block.settings.icon_size }}px;
					margin: {{ block.settings.margin_icon }};
				}

				#shopify-section-{{ section.id }} .why-choose-us__icon{
					font-size: {{ block.settings.icon_font_size }}px;
					color: {{ block.settings.icon_color }};
				}

				/* ===== MOBILE RESPONSIVE ===== */
				@media (max-width: 767px){
					#shopify-section-{{ section.id }} .why-choose-us__title{
						font-size: {{ block.settings.font_size_title_mobi }}px;
						line-height: {{ block.settings.line_height_title_mobi }}px;
						margin: {{ block.settings.margin_title_mobi }};
					}

					#shopify-section-{{ section.id }} .why-choose-us__feature-title{
						font-size: {{ block.settings.font_size_feature_title_mobi }}px;
						line-height: {{ block.settings.line_height_feature_title_mobi }}px;
						margin: {{ block.settings.margin_feature_title_mobi }};
					}

					#shopify-section-{{ section.id }} .why-choose-us__feature-desc{
						font-size: {{ block.settings.font_size_feature_desc_mobi }}px;
						line-height: {{ block.settings.line_height_feature_desc_mobi }}px;
						margin: {{ block.settings.margin_feature_desc_mobi }};
					}

					#shopify-section-{{ section.id }} .why-choose-us__icon-wrapper{
						width: {{ block.settings.icon_size_mobi }}px;
						height: {{ block.settings.icon_size_mobi }}px;
					}

					#shopify-section-{{ section.id }} .why-choose-us__icon{
						font-size: {{ block.settings.icon_font_size_mobi }}px;
					}
				}
			{%- endif -%}
		{%- endfor -%}
	{%- endif -%}

	{%- comment -%}
	=== WHY CHOOSE US SECTION - RESPONSIVE GRID LAYOUT ===
	This section implements a "Why Choose Us" feature showcase with:
	- Responsive 3-column grid layout (desktop)
	- 1-column layout on mobile
	- Icon + Title + Description structure
	- Circular icon backgrounds with customizable colors
	- Full text customization (font, size, color, spacing)
	
	LAYOUT:
	- Desktop: 3 equal columns with 30px gap
	- Tablet (768px-991px): 2-3 columns based on content
	- Mobile: 1 column full width
	
	TO ADJUST GRID COLUMNS:
	- Change data-column settings in the grid
	- Current: 3 columns on desktop, 1 on mobile
	- Modify data-column1440, data-column1, data-column2, etc.
	{%- endcomment -%}

	/* Base section styling */
	#shopify-section-{{ section.id }} .wpbingo-why-choose-us {
		width: 100%;
	}

	#shopify-section-{{ section.id }} .why-choose-us__wrapper {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 30px;
		width: 100%;
	}

	/* Individual feature item styling */
	#shopify-section-{{ section.id }} .why-choose-us__item {
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;
		padding: 20px;
	}

	/* Icon wrapper - circular background container */
	#shopify-section-{{ section.id }} .why-choose-us__icon-wrapper {
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		transition: transform 0.3s ease, box-shadow 0.3s ease;
	}

	/* Hover effect for icon wrapper */
	#shopify-section-{{ section.id }} .why-choose-us__item:hover .why-choose-us__icon-wrapper {
		transform: scale(1.05);
		box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
	}

	/* Icon styling */
	#shopify-section-{{ section.id }} .why-choose-us__icon {
		display: flex;
		align-items: center;
		justify-content: center;
	}

	/* Feature title styling */
	#shopify-section-{{ section.id }} .why-choose-us__feature-title {
		margin-top: 20px;
		margin-bottom: 10px;
	}

	/* Feature description styling */
	#shopify-section-{{ section.id }} .why-choose-us__feature-desc {
		max-width: 100%;
		line-height: 1.6;
	}

	/* Responsive: Tablet (max 991px) */
	@media (max-width: 991px) {
		#shopify-section-{{ section.id }} .why-choose-us__wrapper {
			grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
			gap: 20px;
		}

		#shopify-section-{{ section.id }} .why-choose-us__item {
			padding: 15px;
		}
	}

	/* Responsive: Mobile (max 767px) */
	@media (max-width: 767px) {
		#shopify-section-{{ section.id }} .why-choose-us__wrapper {
			grid-template-columns: 1fr;
			gap: 25px;
		}

		#shopify-section-{{ section.id }} .why-choose-us__item {
			padding: 15px 0;
		}

		#shopify-section-{{ section.id }} .why-choose-us__feature-desc {
			font-size: 14px;
		}
	}

{%- endstyle -%}

<!-- Why Choose Us Section -->
<section class="wpbingo-section wpbingo-why-choose-us overflow-hidden wpbingo-section--{{ section.id }}" data-id="{{ section.id }}">
	<div class="{{ container }}" {{ max_width }}>
		<div class="wpbingo-section__inner">
			<!-- Section Title -->
			{%- if section.settings.title -%}
				<h2 class="why-choose-us__title">{{ section.settings.title }}</h2>
			{%- endif -%}

			<!-- Features Grid -->
			<div class="why-choose-us__wrapper">
				{%- for block in section.blocks -%}
					{%- if block.type == 'feature' -%}
						<div class="why-choose-us__item" {{ block.shopify_attributes }}>
							<!-- Icon Container -->
							<div class="why-choose-us__icon-wrapper">
								{%- if block.settings.icon_type == 'custom' and block.settings.custom_icon -%}
									<!-- Custom Icon Class (e.g., FontAwesome) -->
									<i class="why-choose-us__icon {{ block.settings.custom_icon }}"></i>
								{%- elsif block.settings.icon_type == 'image' and block.settings.icon_image -%}
									<!-- Image Icon -->
									{% render 'img-global' with image: block.settings.icon_image, class: "why-choose-us__icon-img", width: 50, height: 50 %}
								{%- else -%}
									<!-- Fallback empty icon -->
									<i class="why-choose-us__icon"></i>
								{%- endif -%}
							</div>

							<!-- Feature Title -->
							{%- if block.settings.feature_title -%}
								<h3 class="why-choose-us__feature-title">{{ block.settings.feature_title }}</h3>
							{%- endif -%}

							<!-- Feature Description -->
							{%- if block.settings.feature_desc -%}
								<p class="why-choose-us__feature-desc">{{ block.settings.feature_desc }}</p>
							{%- endif -%}
						</div>
					{%- endif -%}
				{%- endfor -%}
			</div>
		</div>
	</div>
</section>

