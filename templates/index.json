    "seo_how_it_works_section": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<section class=\"seo-how-it-works\" style=\"padding:80px 0 60px;background:#fff;\">\n  <div class=\"container\">\n    <h2 style=\"text-align:center;font-size:32px;font-weight:700;margin-bottom:12px;font-family:var(--font-family-second,serif);\">\n      How to Apply Press-On Nails in 4 Steps\n    </h2>\n    <p style=\"text-align:center;color:#666;margin-bottom:48px;font-size:16px;\">\n      Salon-quality nails from the comfort of home. No tools, no appointments, no experience needed.\n    </p>\n    <div style=\"display:flex;flex-wrap:wrap;gap:24px;justify-content:center;\">\n      <div style=\"flex:1;min-width:200px;max-width:240px;text-align:center;padding:24px 16px;\">\n        <div style=\"width:56px;height:56px;background:#000;color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:22px;font-weight:700;margin:0 auto 16px;\">1</div>\n        <h3 style=\"font-size:17px;font-weight:600;margin-bottom:8px;\">Prep Your Nails</h3>\n        <p style=\"font-size:14px;color:#666;line-height:1.6;\">Push back cuticles, clean nail surfaces with the included prep pad. Dry completely.</p>\n      </div>\n      <div style=\"flex:1;min-width:200px;max-width:240px;text-align:center;padding:24px 16px;\">\n        <div style=\"width:56px;height:56px;background:#000;color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:22px;font-weight:700;margin:0 auto 16px;\">2</div>\n        <h3 style=\"font-size:17px;font-weight:600;margin-bottom:8px;\">Find Your Size</h3>\n        <p style=\"font-size:14px;color:#666;line-height:1.6;\">Match each nail from the 15 sizes included in your kit. ZUVE sets contain multiple sizes so every finger fits perfectly.</p>\n      </div>\n      <div style=\"flex:1;min-width:200px;max-width:240px;text-align:center;padding:24px 16px;\">\n        <div style=\"width:56px;height:56px;background:#000;color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:22px;font-weight:700;margin:0 auto 16px;\">3</div>\n        <h3 style=\"font-size:17px;font-weight:600;margin-bottom:8px;\">Peel &amp; Press</h3>\n        <p style=\"font-size:14px;color:#666;line-height:1.6;\">Remove the adhesive tab backing. Align the nail from cuticle to tip and press firmly for 10 seconds.</p>\n      </div>\n      <div style=\"flex:1;min-width:200px;max-width:240px;text-align:center;padding:24px 16px;\">\n        <div style=\"width:56px;height:56px;background:#000;color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:22px;font-weight:700;margin:0 auto 16px;\">4</div>\n        <h3 style=\"font-size:17px;font-weight:600;margin-bottom:8px;\">You're Done</h3>\n        <p style=\"font-size:14px;color:#666;line-height:1.6;\">Salon-quality nails, in under 10 minutes. Apply to all fingers and enjoy perfect nails instantly.</p>\n      </div>\n    </div>\n    <div style=\"text-align:center;margin-top:36px;\">\n      <a href=\"/pages/how-to-apply-press-on-nails\" style=\"display:inline-block;padding:12px 32px;border:1px solid #000;font-size:13px;letter-spacing:1px;text-transform:uppercase;color:#000;text-decoration:none;font-weight:500;\">\n        Full Application Guide &rarr;\n      </a>\n    </div>\n  </div>\n</section>"
      }
    },
    "seo_comparison_section": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<section class=\"seo-comparison\" style=\"padding:80px 0;background:#f9f6f3;\">\n  <div class=\"container\">\n    <h2 style=\"text-align:center;font-size:30px;font-weight:700;margin-bottom:12px;font-family:var(--font-family-second,serif);\">\n      Why More Indian Women Are Switching to Press-On Nails\n    </h2>\n    <p style=\"text-align:center;color:#555;margin-bottom:40px;font-size:16px;max-width:680px;margin-left:auto;margin-right:auto;\">\n      Salon nail extensions are expensive, time-consuming, and can damage your natural nails over time. ZUVE press-on nails deliver the same salon-quality result &mdash; at home, in minutes, for a fraction of the cost.\n    </p>\n    <div style=\"overflow-x:auto;\">\n      <table style=\"width:100%;max-width:760px;margin:0 auto;border-collapse:collapse;font-size:15px;\">\n        <thead>\n          <tr>\n            <th style=\"padding:14px 16px;background:#f0ece8;border:1px solid #ddd;text-align:left;font-weight:600;width:180px;\"></th>\n            <th style=\"padding:14px 16px;background:#f0ece8;border:1px solid #ddd;text-align:center;font-weight:600;\">Salon Nail Extensions</th>\n            <th style=\"padding:14px 16px;background:#000;border:1px solid #000;text-align:center;font-weight:700;color:#fff;\">ZUVE Press-On Nails</th>\n          </tr>\n        </thead>\n        <tbody>\n          <tr>\n            <td style=\"padding:13px 16px;border:1px solid #ddd;font-weight:600;\">Cost</td>\n            <td style=\"padding:13px 16px;border:1px solid #ddd;text-align:center;color:#666;\">&#8377;800&ndash;&#8377;3,000 per visit</td>\n            <td style=\"padding:13px 16px;border:1px solid #000;text-align:center;font-weight:600;background:#fafafa;\">&#8377;599&ndash;&#8377;1,299 per set</td>\n          </tr>\n          <tr style=\"background:#f9f9f9;\">\n            <td style=\"padding:13px 16px;border:1px solid #ddd;font-weight:600;\">Time</td>\n            <td style=\"padding:13px 16px;border:1px solid #ddd;text-align:center;color:#666;\">90&ndash;120 minutes</td>\n            <td style=\"padding:13px 16px;border:1px solid #000;text-align:center;font-weight:600;background:#fafafa;\">Under 10 minutes</td>\n          </tr>\n          <tr>\n            <td style=\"padding:13px 16px;border:1px solid #ddd;font-weight:600;\">Nail Damage</td>\n            <td style=\"padding:13px 16px;border:1px solid #ddd;text-align:center;color:#666;\">Drilling &amp; filing required</td>\n            <td style=\"padding:13px 16px;border:1px solid #000;text-align:center;font-weight:600;background:#fafafa;\">Zero damage. Reusable tabs.</td>\n          </tr>\n          <tr style=\"background:#f9f9f9;\">\n            <td style=\"padding:13px 16px;border:1px solid #ddd;font-weight:600;\">Reusable</td>\n            <td style=\"padding:13px 16px;border:1px solid #ddd;text-align:center;color:#666;\">No &mdash; removed with chemicals</td>\n            <td style=\"padding:13px 16px;border:1px solid #000;text-align:center;font-weight:600;background:#fafafa;\">Yes &mdash; wear up to 10+ times</td>\n          </tr>\n          <tr>\n            <td style=\"padding:13px 16px;border:1px solid #ddd;font-weight:600;\">Convenience</td>\n            <td style=\"padding:13px 16px;border:1px solid #ddd;text-align:center;color:#666;\">Appointment needed</td>\n            <td style=\"padding:13px 16px;border:1px solid #000;text-align:center;font-weight:600;background:#fafafa;\">Apply at home, anytime</td>\n          </tr>\n          <tr style=\"background:#f9f9f9;\">\n            <td style=\"padding:13px 16px;border:1px solid #ddd;font-weight:600;\">Designs</td>\n            <td style=\"padding:13px 16px;border:1px solid #ddd;text-align:center;color:#666;\">Limited to salon stock</td>\n            <td style=\"padding:13px 16px;border:1px solid #000;text-align:center;font-weight:600;background:#fafafa;\">New collections every season</td>\n          </tr>\n        </tbody>\n      </table>\n    </div>\n    <div style=\"text-align:center;margin-top:36px;\">\n      <a href=\"/collections/all\" style=\"display:inline-block;padding:14px 36px;background:#000;color:#fff;font-size:13px;letter-spacing:1px;text-transform:uppercase;text-decoration:none;font-weight:500;\">\n        Shop All Nail Sets &rarr;\n      </a>\n    </div>\n  </div>\n</section>"
      }
