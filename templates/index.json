    "seo_faq_section": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<section class=\"seo-faq-homepage\" style=\"padding:80px 0 60px;background:#fff;\">\n  <div class=\"container\">\n    <h2 style=\"text-align:center;font-size:30px;font-weight:700;margin-bottom:12px;font-family:var(--font-family-second,serif);\">\n      Frequently Asked Questions About Press-On Nails\n    </h2>\n    <p style=\"text-align:center;color:#666;margin-bottom:48px;font-size:16px;\">\n      Everything you need to know before your first ZUVE order.\n    </p>\n    <div style=\"max-width:760px;margin:0 auto;\" class=\"zuve-faq-list\">\n      <style>\n        .zuve-faq-item{border-bottom:1px solid #e8e8e8;overflow:hidden;}\n        .zuve-faq-question{width:100%;background:none;border:none;text-align:left;padding:18px 0;font-size:16px;font-weight:600;cursor:pointer;display:flex;justify-content:space-between;align-items:center;color:#000;}\n        .zuve-faq-question:after{content:'+';font-size:22px;font-weight:300;transition:transform .3s;}\n        .zuve-faq-question.open:after{transform:rotate(45deg);}\n        .zuve-faq-answer{max-height:0;overflow:hidden;transition:max-height .35s ease;font-size:15px;color:#444;line-height:1.75;}\n        .zuve-faq-answer.open{max-height:500px;padding-bottom:18px;}\n      </style>\n      <div class=\"zuve-faq-item\">\n        <button class=\"zuve-faq-question\">What are press-on nails?</button>\n        <div class=\"zuve-faq-answer\">Press-on nails are pre-shaped artificial nails that attach to your natural nails using adhesive tabs or nail glue. ZUVE press-on nails are made from premium soft gel and are designed to look identical to professional acrylic nail extensions &mdash; applied at home in under 10 minutes.</div>\n      </div>\n      <div class=\"zuve-faq-item\">\n        <button class=\"zuve-faq-question\">How long do ZUVE press-on nails last?</button>\n        <div class=\"zuve-faq-answer\">With proper application and care, ZUVE press-on nails last 5&ndash;7 days with the included adhesive tabs. For special occasions, they can last up to 2 weeks when used with nail glue (sold separately). Wear time depends on nail prep and lifestyle.</div>\n      </div>\n      <div class=\"zuve-faq-item\">\n        <button class=\"zuve-faq-question\">Are ZUVE press-on nails reusable?</button>\n        <div class=\"zuve-faq-answer\">Yes! ZUVE nails are designed to be reusable. Remove them carefully by soaking in warm water for 5&ndash;10 minutes, clean the adhesive residue, and store them in the included case. Each set can be worn 5&ndash;10+ times.</div>\n      </div>\n      <div class=\"zuve-faq-item\">\n        <button class=\"zuve-faq-question\">Do press-on nails damage your natural nails?</button>\n        <div class=\"zuve-faq-answer\">No. When applied and removed correctly, ZUVE press-on nails cause zero damage to your natural nails. Unlike acrylic nail extensions that require drilling and filing, our nails use gentle adhesive tabs that lift off without harming the nail plate.</div>\n      </div>\n      <div class=\"zuve-faq-item\">\n        <button class=\"zuve-faq-question\">What sizes come in a ZUVE nail set?</button>\n        <div class=\"zuve-faq-answer\">Every ZUVE set includes 15 nail sizes (2 of each size: XS to XL) &mdash; 30 nails in total. This ensures a perfect fit for every finger shape. A sizing guide is included with every order.</div>\n      </div>\n      <div class=\"zuve-faq-item\">\n        <button class=\"zuve-faq-question\">How much do ZUVE press-on nails cost?</button>\n        <div class=\"zuve-faq-answer\">ZUVE nail sets are priced between &#8377;599 and &#8377;1,299. We offer free shipping on orders above &#8377;1,500. All prices are in INR and payments are accepted via UPI, credit/debit cards, and Cash on Delivery (COD).</div>\n      </div>\n    </div>\n    <div style=\"text-align:center;margin-top:40px;\">\n      <a href=\"/pages/faq\" style=\"display:inline-block;padding:12px 32px;border:1px solid #000;font-size:13px;letter-spacing:1px;text-transform:uppercase;color:#000;text-decoration:none;font-weight:500;\">\n        View All FAQs &rarr;\n      </a>\n    </div>\n  </div>\n  <script>\n    document.querySelectorAll('.zuve-faq-question').forEach(function(btn){\n      btn.addEventListener('click',function(){\n        var ans=this.nextElementSibling;\n        var isOpen=ans.classList.contains('open');\n        document.querySelectorAll('.zuve-faq-answer').forEach(function(a){a.classList.remove('open');});\n        document.querySelectorAll('.zuve-faq-question').forEach(function(b){b.classList.remove('open');});\n        if(!isOpen){ans.classList.add('open');this.classList.add('open');}\n      });\n    });\n  </script>\n</section>"
      }
    }
